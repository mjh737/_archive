  </EntityType>
  <Association Name="FK_FoodItems_FoodCategories">
    <End Role="FoodCategories" Type="LonelyOutpostModel.Store.FoodCategories" Multiplicity="1" />
    <End Role="FoodItems" Type="LonelyOutpostModel.Store.FoodItems" Multiplicity="*" />
    <ReferentialConstraint>
      <Principal Role="FoodCategories">
        <PropertyRef Name="CategoryID" />
      </Principal>
      <Dependent Role="FoodItems">
        <PropertyRef Name="Category" />
      </Dependent>
    </ReferentialConstraint>
  </Association>
  <Association Name="FK_FoodJournal_FoodItems">
